   "source": [
    "plt.figure(figsize=(8, 5))\n",
    "colors = ['#2ecc71', '#e74c3c']\n",
    "labels = ['No Heart Disease', 'Has Heart Disease']\n",
    "counts = df['condition_'].value_counts().sort_index()\n",
    "\n",
    "plt.bar(labels, counts, color=colors, edgecolor='black', width=0.5)\n",
    "plt.title('Heart Disease Distribution', fontsize=16, fontweight='bold')\n",
    "plt.ylabel('Number of Patients')\n",
    "plt.xlabel('Disease Status')\n",
    "for i, v in enumerate(counts):\n",
    "    plt.text(i, v + 2, str(v), ha='center', fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.savefig('outputs/chart1_disease_distribution.png', dpi=150)\n",
    "plt.show()"
   ]
  },
