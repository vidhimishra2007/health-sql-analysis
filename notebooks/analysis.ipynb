   "source": [
    "import os\n",
    "from dotenv import load_dotenv\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from sqlalchemy import create_engine\n",
    "\n",
    "# Load password from .env file\n",
    "load_dotenv()\n",
    "password = os.getenv('DB_PASSWORD')\n",
    "\n",
    "# Connect to MySQL\n",
    "engine = create_engine(f'mysql+mysqlconnector://root:{password}@localhost/health_analysis')\n",
    "\n",
    "# Test\n",
    "df = pd.read_sql('SELECT COUNT(*) AS TOTAL FROM HEART_DISEASE', engine)\n",
    "print(df)"
   ]
  }
