   "source": [
    "chol_data = df.groupby('condition_')['chol'].mean().reset_index()\n",
    "chol_data['condition_'] = chol_data['condition_'].map({0: 'No Disease', 1: 'Has Disease'})\n",
    "\n",
    "plt.figure(figsize=(8, 5))\n",
    "plt.bar(chol_data['condition_'], chol_data['chol'], \n",
    "        color=['#2ecc71', '#e74c3c'], edgecolor='black', width=0.5)\n",
    "plt.title('Average Cholesterol by Disease Status', fontsize=16, fontweight='bold')\n",
    "plt.ylabel('Average Cholesterol (mg/dl)')\n",
    "plt.xlabel('Disease Status')\n",
    "for i, v in enumerate(chol_data['chol']):\n",
    "    plt.text(i, v + 1, f'{v:.1f}', ha='center', fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.savefig('outputs/chart3_cholesterol.png', dpi=150)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
